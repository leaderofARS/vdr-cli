{
  "name": "@sipheron/vdr-cli",
  "version": "0.1.3",
  "description": "Anchor and verify documents on Solana from your terminal. No account required.",
  "bin": {
    "sipheron": "dist/index.js"
  },
  "main": "./dist/index.js",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc && chmod +x dist/index.js",
    "dev": "ts-node src/index.js",
    "test": "jest",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@sipheron/vdr-core": "file:../vdr-core",
    "@solana/web3.js": "^1.91.1",
    "axios": "^1.13.6",
    "chalk": "^4.1.2",
    "cli-table3": "^0.6.3",
